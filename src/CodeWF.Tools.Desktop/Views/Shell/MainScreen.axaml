<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="using:CodeWF.Tools.Desktop.ViewModels"
             xmlns:shell="using:CodeWF.Tools.Desktop.Views.Shell"
             x:Class="CodeWF.Tools.Desktop.Views.Shell.MainScreen"
             x:DataType="vm:MainViewModel"
             d:DesignWidth="1000" d:DesignHeight="1000"
             x:CompileBindings="True">
    <DockPanel IsEnabled="{Binding IsMainContentEnabled}">
        <shell:TitleBar DockPanel.Dock="Top" />
    </DockPanel>
</UserControl>